# Required: v0 Platform API key
# https://v0.app/chat/settings/keys
V0_API_KEY=your_v0_api_key_here

# v0 Platform API base URL (must include /v1)
V0_API_BASE_URL=https://api.v0.dev/v1

# Local OpenAI-style proxy server
HOST=127.0.0.1
PORT=3000

# Optional local API key expected by your proxy clients
OPENAI_API_KEY=local-dev-openai-key

# Local persistence for conversation -> chatId mapping
CHAT_STATE_FILE=.data/chat-state.db

# Set to false for API-only deployments that do not ship the dashboard bundle
SERVE_WEB_UI=true

# Must remain true for this project (use /v1/chats workflow)
V0_USE_CHATS_API=true
